# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public keys — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never expose to the client
# Used by admin operations that bypass Row Level Security
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Sync security ─────────────────────────────────────────────────────────────
# Secret for protecting the POST /api/sync/ownerrez endpoint
# Used for external webhook or manual curl triggers
# Generate with: openssl rand -hex 32
SYNC_SECRET=your-random-secret-here

# ── Vercel Cron (auto-set by Vercel — do NOT set manually) ───────────────────
# Vercel automatically injects CRON_SECRET into every cron job request as:
#   Authorization: Bearer <CRON_SECRET>
# The GET handlers on /api/sync/ownerrez and /api/recommendations/generate
# validate this header. You do not need to set this in Vercel's dashboard —
# it is provisioned automatically per project.
# CRON_SECRET=auto-set-by-vercel
